{
	"_version": "1.60.0",
	"sap.app": {
		"id": "com.laravelui5.auth",
		"type": "application",
		"i18n": {
			"bundleUrl": "i18n/i18n.properties",
			"supportedLocales": [
				"",
				"de",
				"en"
			]
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"applicationVersion": {
			"version": "0.2.1"
		},
		"sourceTemplate": {
			"id": "generator-ui5-ts-app",
			"version": "1.1.0"
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"rootView": {
			"viewName": "com.laravelui5.auth.view.App",
			"type": "XML",
			"id": "app"
		},
		"dependencies": {
			"minUI5Version": "1.136.8",
			"libs": {
				"sap.ui.core": {},
				"sap.m": {},
				"sap.f": {},
				"com.laravelui5.core": {}
			}
		},
		"handleValidation": true,
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "com.laravelui5.auth.i18n.i18n",
					"supportedLocales": [
						"en",
						"de"
					],
					"fallbackLocale": "en",
					"async": true
				}
			}
		},
		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"type": "View",
				"viewType": "XML",
				"path": "com.laravelui5.auth.view",
				"controlId": "app",
				"controlAggregation": "pages"
			},
			"routes": [
				{
					"pattern": "",
					"name": "login",
					"target": "login"
				},
				{
					"pattern": "forgot-password",
					"name": "ForgotPassword",
					"target": "ForgotPassword"
				},
				{
					"pattern": "set-password/{token}/{email}",
					"name": "SetPassword",
					"target": "SetPassword"
				},
				{
					"pattern": "org-setup",
					"name": "OrgSetup",
					"target": "OrgSetup"
				}
			],
			"targets": {
				"login": {
					"id": "login",
					"name": "Login"
				},
				"ForgotPassword": {
					"id": "forgot",
					"name": "ForgotPassword"
				},
				"SetPassword": {
					"id": "set",
					"name": "SetPassword"
				},
				"OrgSetup": {
					"id": "orgSetup",
					"name": "OrgSetup"
				}
			}
		},
		"flexBundle": false
	}
}