<mvc:View
	controllerName="io.pragmatiqu.auth.controller.SetPassword"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:card="sap.f.cards"
	xmlns:core="sap.ui.core"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:f="sap.f"
>
	<FlexBox height="100%" direction="Column" alignItems="Center" justifyContent="Center">
		<f:Card width="25em" height="60vh">
			<f:layoutData>
				<f:GridContainerItemLayoutData columns="4"/>
			</f:layoutData>
			<f:header>
				<card:Header title="{i18n>setPassword.title}" />
			</f:header>
			<f:content>
				<FlexBox direction="Column" justifyContent="SpaceBetween" width="90%" height="100%">
					<VBox width="100%" class="sapUiMediumMarginTop sapUiSmallMargin">
						<MessageStrip
							visible="{setPassword>/result/visible}"
							type="{setPassword>/result/type}"
							text="{setPassword>/result/text}"
							showIcon="true"
							class="sapUiSmallMarginBottom"
						/>

						<VBox visible="{= !${setPassword>/done}}">
							<Label design="Bold" text="{i18n>setPassword.emailLabel}" class="sapUiNoMargin"/>
							<Input
								id="emailInput"
								width="100%"
								value="{login>/email}"
								editable="false"
							/>

							<Label design="Bold" text="{i18n>setPassword.passwordLabel}" class="sapUiSmallMarginTop"/>
							<Input
								id="passwordInput"
								width="100%"
								value="{login>/password}"
								valueLiveUpdate="true"
								type="Password"
								placeholder="{i18n>setPassword.passwordPlaceholder}"
							/>

							<Label design="Bold" text="{i18n>setPassword.passwordConfirmationLabel}" class="sapUiSmallMarginTop"/>
							<Input
								id="passwordConfirmationInput"
								width="100%"
								value="{login>/passwordConfirmation}"
								valueLiveUpdate="true"
								type="Password"
								placeholder="{i18n>setPassword.passwordConfirmationPlaceholder}"
							/>
						</VBox>

						<HBox justifyContent="End" width="100%" visible="{setPassword>/done}" class="sapUiSmallMarginTop">
							<Link text="{i18n>setPassword.signinLink}" href="#/" />
						</HBox>
					</VBox>

					<VBox
						alignItems="End"
						width="100%"
						class="sapUiMediumMarginTop sapUiSmallMargin"
						visible="{= !${setPassword>/done}}"
					>
						<Button
							text="{i18n>setPassword.continue}"
							type="Emphasized"
							width="auto"
							press=".onContinue"
							enabled="{= !!${login>/password} &amp;&amp; !!${login>/passwordConfirmation} &amp;&amp; !${setPassword>/submitting}}"
						/>
					</VBox>
				</FlexBox>
			</f:content>
		</f:Card>

		<core:Fragment fragmentName="io.pragmatiqu.auth.view.LegalFooter" type="XML"/>
	</FlexBox>
</mvc:View>
