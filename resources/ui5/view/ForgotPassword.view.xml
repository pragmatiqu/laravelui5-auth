<mvc:View
	controllerName="io.pragmatiqu.auth.controller.ForgotPassword"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:card="sap.f.cards"
	xmlns:core="sap.ui.core"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:f="sap.f"
>
	<FlexBox height="100%" direction="Column" alignItems="Center" justifyContent="Center">
		<f:Card width="25em" height="60vh">
			<f:layoutData>
				<f:GridContainerItemLayoutData columns="4"/>
			</f:layoutData>
			<f:header>
				<card:Header title="Forgot Password" />
			</f:header>
			<f:content>
				<FlexBox direction="Column" justifyContent="SpaceBetween" width="90%" height="100%">
					<VBox width="100%" class="sapUiMediumMarginTop sapUiSmallMargin">
						<MessageStrip
							visible="{forgotPassword>/result/visible}"
							type="{forgotPassword>/result/type}"
							text="{forgotPassword>/result/text}"
							showIcon="true"
							class="sapUiSmallMarginBottom"
						/>

						<Label design="Bold" text="Login" class="sapUiNoMargin"/>
						<Input
							id="emailInput"
							width="100%"
							value="{login>/email}"
							valueLiveUpdate="true"
							placeholder="Enter email associated with your account"
						/>

						<HBox justifyContent="End" width="100%">
								<Link text="{i18n>forgotPassword.back}" href="#/"/>
						</HBox>
					</VBox>

					<VBox alignItems="End" width="100%" class="sapUiMediumMarginTop sapUiSmallMargin">
						<Button
							text="{i18n>forgotPassword.continue}"
							type="Emphasized"
							width="auto"
							press=".onContinue"
							enabled="{= !!${login>/email} &amp;&amp; !${forgotPassword>/submitting}}"
						/>
					</VBox>
				</FlexBox>
			</f:content>
		</f:Card>

		<core:Fragment fragmentName="io.pragmatiqu.auth.view.LegalFooter" type="XML"/>
	</FlexBox>
</mvc:View>
