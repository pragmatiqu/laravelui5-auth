<mvc:View
	controllerName="io.pragmatiqu.auth.controller.OrgSetup"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:card="sap.f.cards"
	xmlns:core="sap.ui.core"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:f="sap.f"
>
	<FlexBox height="100%" direction="Column" alignItems="Center" justifyContent="Center">
		<f:Card width="32em">
			<f:layoutData>
				<f:GridContainerItemLayoutData columns="4"/>
			</f:layoutData>
			<f:header>
				<card:Header title="{i18n>orgSetup.title}" subtitle="{i18n>orgSetup.subtitle}"/>
			</f:header>
			<f:content>
				<VBox width="90%" class="sapUiMediumMarginTop sapUiSmallMargin">
					<MessageStrip
						visible="{orgSetup>/result/visible}"
						type="{orgSetup>/result/type}"
						text="{orgSetup>/result/text}"
						showIcon="true"
						class="sapUiSmallMarginBottom"
					/>

					<Label design="Bold" text="{i18n>orgSetup.legalForm.label}" required="true" class="sapUiNoMargin"/>
					<RadioButtonGroup
						id="legalFormGroup"
						selectedIndex="{= ${orgSetup>/legal_form} === 1 ? 0 : (${orgSetup>/legal_form} === 2 ? 1 : -1) }"
						select=".onLegalFormSelect"
						columns="2"
						class="sapUiTinyMarginBottom"
					>
						<RadioButton text="{i18n>orgSetup.legalForm.soleProprietor}"/>
						<RadioButton text="{i18n>orgSetup.legalForm.company}"/>
					</RadioButtonGroup>

					<Label design="Bold" text="{i18n>orgSetup.orgName.label}" required="true" class="sapUiNoMargin"/>
					<Input
						value="{orgSetup>/org_name}"
						valueLiveUpdate="true"
						placeholder="{i18n>orgSetup.orgName.placeholder}"
						class="sapUiTinyMarginBottom"
					/>
					<Label
						visible="{= ${orgSetup>/legal_form} === 1 }"
						text="{i18n>orgSetup.orgName.soleProprietorHint}"
						class="sapUiTinyMarginBottom"
					/>

					<Label design="Bold" text="{i18n>orgSetup.companySize.label}" required="true" class="sapUiNoMargin"/>
					<Select
						selectedKey="{orgSetup>/company_size}"
						forceSelection="false"
						class="sapUiTinyMarginBottom"
					>
						<core:Item key="solo"       text="{i18n>orgSetup.companySize.solo}"/>
						<core:Item key="small"      text="{i18n>orgSetup.companySize.small}"/>
						<core:Item key="growing"    text="{i18n>orgSetup.companySize.growing}"/>
						<core:Item key="mid_market" text="{i18n>orgSetup.companySize.midMarket}"/>
						<core:Item key="enterprise" text="{i18n>orgSetup.companySize.enterprise}"/>
					</Select>

					<Label design="Bold" text="{i18n>orgSetup.function.label}" required="true" class="sapUiNoMargin"/>
					<Select
						selectedKey="{orgSetup>/function}"
						forceSelection="false"
						class="sapUiTinyMarginBottom"
					>
						<core:Item key="developer" text="{i18n>orgSetup.function.developer}"/>
						<core:Item key="tech_lead" text="{i18n>orgSetup.function.techLead}"/>
						<core:Item key="architect" text="{i18n>orgSetup.function.architect}"/>
						<core:Item key="executive" text="{i18n>orgSetup.function.executive}"/>
						<core:Item key="other"     text="{i18n>orgSetup.function.other}"/>
					</Select>

					<Label design="Bold" text="{i18n>orgSetup.billingEmail.label}" class="sapUiNoMargin"/>
					<Input
						value="{orgSetup>/billing_email}"
						valueLiveUpdate="true"
						type="Email"
						placeholder="{i18n>orgSetup.billingEmail.placeholder}"
					/>
					<Label
						text="{i18n>orgSetup.billingEmail.hint}"
						class="sapUiTinyMarginBottom"
					/>

					<CheckBox
						selected="{orgSetup>/marketing_consent}"
						text="{i18n>orgSetup.marketingConsent}"
						class="sapUiSmallMarginTop"
					/>

					<HBox justifyContent="End" width="100%" class="sapUiMediumMarginTop">
						<Button
							text="{i18n>orgSetup.continue}"
							type="Emphasized"
							press=".onSubmit"
							enabled="{= ${orgSetup>/legal_form} > 0
								&amp;&amp; !!${orgSetup>/org_name}
								&amp;&amp; !!${orgSetup>/company_size}
								&amp;&amp; !!${orgSetup>/function}
								&amp;&amp; !${orgSetup>/submitting} }"
						/>
					</HBox>
				</VBox>
			</f:content>
		</f:Card>

		<core:Fragment fragmentName="io.pragmatiqu.auth.view.LegalFooter" type="XML"/>
	</FlexBox>
</mvc:View>
