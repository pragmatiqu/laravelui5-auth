<mvc:View
	controllerName="io.pragmatiqu.auth.controller.Login"
	displayBlock="true"
	xmlns="sap.m"
	xmlns:card="sap.f.cards"
	xmlns:core="sap.ui.core"
	xmlns:f="sap.f"
	xmlns:mvc="sap.ui.core.mvc"
>
	<FlexBox height="100%" direction="Column" alignItems="Center" justifyContent="Center">
		<f:Card width="25em" height="60vh">
			<f:layoutData>
					<f:GridContainerItemLayoutData columns="4"/>
			</f:layoutData>
			<f:header>
				<card:Header title="Sign In" />
			</f:header>
			<f:content>
				<FlexBox direction="Column" justifyContent="SpaceBetween" width="90%" height="100%">
					<VBox width="100%" class="sapUiMediumMarginTop sapUiSmallMargin">
							<Label design="Bold" text="Login" class="sapUiNoMargin"/>
							<Input
									id="emailInput"
									width="100%"
									value="{login>/email}"
									valueLiveUpdate="true"
									placeholder="Enter E-Mail"/>

							<Label design="Bold" text="Password" class="sapUiSmallMarginTop"/>
							<Input
									class="sapUiNoPadding"
									id="passwordInput"
									width="100%"
									value="{login>/password}"
									valueLiveUpdate="true"
									type="Password"
									placeholder="Enter password"/>

							<HBox justifyContent="End" width="100%" class="sapUiTinyMarginTop">
								<Link text="Forgot Password" href="#/forgot-password" />
							</HBox>

							<CheckBox
								text="Keep me signed in"
								selected="false"
								name="keepSignedIn"
								class="sapUiNoContentPadding sapUiSmallMarginTop"
							/>
					</VBox>

					<VBox alignItems="End" width="100%" class="sapUiMediumMarginTop sapUiSmallMargin">
							<Button text="Continue" type="Emphasized" width="auto" press=".onLogin" />
					</VBox>
				</FlexBox>
			</f:content>
		</f:Card>

		<core:Fragment fragmentName="io.pragmatiqu.auth.view.LegalFooter" type="XML"/>
	</FlexBox>
</mvc:View>
