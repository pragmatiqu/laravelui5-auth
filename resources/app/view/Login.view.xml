<mvc:View
    controllerName="io.pragmatiqu.auth.controller.Login"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:card="sap.f.cards"
    xmlns:f="sap.f"
>
    <!--TODO: Keine überschrift alles Grau, an alles Zentriert -->

    <FlexBox
        height="100%"
        direction="Column"
        alignItems="Center"
        justifyContent="Center">
        <f:Card width="25em"
                height="60vh">
            <f:layoutData>
                <f:GridContainerItemLayoutData columns="4"/>
            </f:layoutData>
            <f:content>
                <Page class="bg-white">
                    <customHeader>
                        <Toolbar>
                            <Title text="Sign In" level="H1" class="sapUiTinyMarginBegin"/>
                        </Toolbar>
                    </customHeader>
                    <VBox
                        width="90%"
                        class="sapUiMediumMarginTop sapUiSmallMargin"
                    >
                        <Label text="Email, User ID or Login Name" class="sapUiNoMargin"/>
                        <Input
                            id="emailInput"
                            width="100%"
                            value="{login>/email}"
                            placeholder="Enter E-Mail"/>

                        <HBox justifyContent="End" width="100%">
                            <Link
                                text="Change"
                                href="#/Forgot"
                            />
                        </HBox>
                        <Label text="Password" class="sapUiNoMargin"/>
                        <Input
                            class="sapUiNoPadding"
                            id="passwordInput"
                            width="100%"
                            value="{login>/password}"
                            type="Password"
                            placeholder="Enter password"/>

                        <HBox justifyContent="SpaceBetween" width="100%">
                            <CheckBox
                                text="Keep me signed in"
                                selected="false"
                                name="keepSignedIn"
                                class="sapUiNoContentPadding"/>
                            <Link
                                text="Forgot Password"
                                href="#/Forgot"
                                press="onNavigate"
                                class="sapUiSmallMarginTop">
                                <customData>
                                    <core:CustomData key="pattern" value="Forgot" />
                                </customData>
                            </Link>
                        </HBox>
                    </VBox>

                    <footer>
                        <Toolbar>
                            <ToolbarSpacer/>
                            <Button text="Continue" type="Emphasized" width="auto" press=".onContinue" />
                        </Toolbar>
                    </footer>
                </Page>
            </f:content>
        </f:Card>

        <HBox
            justifyContent="Center"
            alignItems="Center"
            width="100%"
            class="sapUiSmallMarginTop sapUiSmallMarginBottom"
        >
            <!-- TODO Links aus Backend mit Ui5Resource und ui5-auth.php lesen -->
            <Link text="Privacy Policy" href="{login>/meta/privacy}" target="_blank" />
            <Text text="  |  " class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
            <Link text="Legal Disclosure" href="{login>/meta/terms}" target="_blank" />
            <Text text="  |  " class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
            <Link text="Cookie Statement" href="{login>/meta/cookies}" target="_blank" />
        </HBox>
    </FlexBox>


</mvc:View>
