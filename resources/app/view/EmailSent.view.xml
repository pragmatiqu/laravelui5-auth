<mvc:View
    controllerName="io.pragmatiqu.auth.controller.App"
    displayBlock="true"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
>
    <FlexBox
        height="100%"
        direction="Column"
        alignItems="Center"
        justifyContent="Center">
        <f:Card width="25em"
                height="60vh">
            <f:layoutData>
                <f:GridContainerItemLayoutData columns="4"/>
            </f:layoutData>
            <f:content>
                <Page class="bg-white">
                    <customHeader>
                        <Toolbar>
                            <Title text="Email sent" level="H1" class="sapUiTinyMarginBegin"/>
                        </Toolbar>
                    </customHeader>
                    <VBox
                        width="90%"
                        class="sapUiMediumMarginTop sapUiSmallMargin"
                    >
                        <Label text="Enter 6-digit code" class="sapUiNoMargin"/>
                        <Input
                            id="code"
                            width="100%"
                            value=""
                            placeholder="Enter Code"/>
                    </VBox>
                    <footer>
                        <Toolbar>
                            <Link text="Back" href="#/"/>
                            <ToolbarSpacer/>
                            <Button text="Confirm" type="Emphasized" width="auto" press=".onConfirm" />
                        </Toolbar>
                    </footer>
                </Page>
            </f:content>
        </f:Card>

        <HBox
            justifyContent="Center"
            alignItems="Center"
            width="100%"
            class="sapUiSmallMarginTop sapUiSmallMarginBottom"
        >
            <!-- TODO Links aus Backend mit Ui5Resource und ui5-auth.php lesen -->
            <Link text="Privacy Policy" href="{login>/meta/privacy}" target="_blank" />
            <Text text="  |  " class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
            <Link text="Legal Disclosure" href="{login>/meta/terms}" target="_blank" />
            <Text text="  |  " class="sapUiTinyMarginBegin sapUiTinyMarginEnd" />
            <Link text="Cookie Statement" href="{login>/meta/cookies}" target="_blank" />
        </HBox>
    </FlexBox>
</mvc:View>
